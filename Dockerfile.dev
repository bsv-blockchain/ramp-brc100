FROM node:22-alpine

WORKDIR /app

# Install dependencies as root so the layer is reusable
COPY package*.json ./
RUN npm install

# Copy source code and hand /app to the unprivileged built-in node user
COPY . .
RUN chown -R node:node /app

USER node

EXPOSE 8080

# Run Vite dev server
CMD ["npm", "run", "dev"]
